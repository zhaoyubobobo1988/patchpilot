# ===== Claude Code subprocess 模式（用 claude CLI + 非 Anthropic 模型）=====
# 填写后 Worker 切换为 spawn claude CLI，通过智谱兼容接口调用 GLM
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
GLM_API_KEY=sk-xxxxxxxx
CLAUDE_CODE_MODEL=glm-4.7
# CLAUDE_CODE_TIMEOUT=300

# ===== LLM 模型（litellm 格式，ANTHROPIC_BASE_URL 未设置时生效）=====
# DeepSeek：deepseek/deepseek-chat 或 deepseek/deepseek-coder
# Anthropic：claude-sonnet-4-6
# OpenAI：openai/gpt-4o
LLM_MODEL=deepseek/deepseek-chat

# ===== API Keys（litellm 自动按模型前缀读取）=====
DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ===== GitHub =====
GITHUB_TOKEN=ghp_...
# 可选：使用 GitHub App 代替 PAT
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=

# ===== 飞书机器人 =====
# 必需：在飞书开放平台 (open.feishu.cn) 创建企业自建应用，获取以下凭证
FEISHU_APP_ID=cli_...
FEISHU_APP_SECRET=...
FEISHU_VERIFICATION_TOKEN=...
# FEISHU_ENCRYPT_KEY=

# ===== Pipeline 行为 =====
# 飞书消息中未指定 repo 时的默认目标仓库
PIPELINE_DEFAULT_REPO=org/repo
MAX_DEBUG_RETRIES=5
MAX_PARALLEL_WORKERS=4
CI_POLL_INTERVAL_SECONDS=30
CI_POLL_TIMEOUT_SECONDS=600

# ===== TypeScript 集成层 =====
TS_BRIDGE_URL=http://localhost:3001
# TS_BRIDGE_PORT=3001

# ===== 工作区 =====
WORKSPACE_BASE_PATH=/tmp/openclaw-workspaces
LOG_LEVEL=INFO
